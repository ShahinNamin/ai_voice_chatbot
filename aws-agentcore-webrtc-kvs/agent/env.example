ELEVENLABS_API_KEY=<Elevenlabs API key>
ELEVENLABS_VOICE_ID=<Elevenlabs voice id>
ELEVENLABS_MODEL_ID=<Elevenlabs model id>


# KVS signaling channel name for managed TURN credential provisioning
# The channel will be auto-created if it doesn't exist
KVS_CHANNEL_NAME=<Kinesis video stream channel name>

# AWS credentials.
# Only needed for local development (PIPECAT_LOCAL_DEV=1).
# When running on AgentCore, credentials come from assumed IAM role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=<AWS region>
RECORDINGS_S3_BUCKET=<Bucket to save the recordings> 
ACTIONS_TABLE=<Dynamodb table to save the actions taken, which will be used by connect>
USERS_TABLE=<Dynamodb table that saves / has user's information>
