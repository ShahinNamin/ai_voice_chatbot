# ── AWS / AgentCore ───────────────────────────────────────────────────────────
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:145770591129:runtime/pipecat_agent-T1WdMP2fiE          # arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/xxxxx
AWS_REGION=us-east-1
SIGNED_URL_EXPIRY_SECONDS=7200

# ── Network ───────────────────────────────────────────────────────────────────
# Elastic Public IP of this EC2/ECS instance — announced in SDP so Chime
# knows where to send RTP. Required; bridge will not start without it.
PUBLIC_IP=3.91.107.118

# Bind address for SIP/RTP sockets.
SIP_BIND_HOST=0.0.0.0

# RTP port range — open these in your Security Group / NACL.
RTP_PORT_MIN=10000
RTP_PORT_MAX=20000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
