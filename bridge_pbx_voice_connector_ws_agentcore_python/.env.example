# ── PBX Bridge environment variables ──────────────────────────────────────
# On EC2/ECS the IAM execution role supplies AWS credentials automatically.
# These variables only need to be set when running locally without a role.

# AWS region where your AgentCore runtime is deployed
AWS_REGION=us-east-1

# Full ARN of the Bedrock AgentCore runtime
# Example: arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/my-agent
AGENT_RUNTIME_ARN=

# How long (seconds) the signed WebSocket URL remains valid
SIGNED_URL_EXPIRY_SECONDS=300

# ── Network ────────────────────────────────────────────────────────────────
# Address/port the SIP listener binds to (UDP)
SIP_HOST=0.0.0.0
SIP_PORT=5060

# Ephemeral RTP port range
RTP_PORT_MIN=10000
RTP_PORT_MAX=20000

# Override auto-detected LAN IP (useful when running behind NAT)
#LOCAL_IP= # Your public IP Address

CHIME_VC_FQDN=abcdef1ghij2klmno3pqr4.voiceconnector.chime.aws

# ── Local development override ────────────────────────────────────────────
# Set to 1 to skip AgentCore and connect to a local Pipecat agent instead
# LOCAL_AGENT=0
# LOCAL_AGENT_WS_URL=ws://localhost:8080/ws
